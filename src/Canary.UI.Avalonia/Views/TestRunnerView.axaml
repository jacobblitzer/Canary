<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Canary.UI.Avalonia.ViewModels"
             xmlns:controls="using:Canary.UI.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
             x:Class="Canary.UI.Avalonia.Views.TestRunnerView"
             x:DataType="vm:TestRunnerViewModel">

  <Grid RowDefinitions="Auto,Auto,*">
    <Border Grid.Row="0" Background="#2D2D30" Padding="8,4">
      <WrapPanel Orientation="Horizontal">
        <TextBlock Text="{Binding StatusText}" Foreground="#DCDCDC" VerticalAlignment="Center" Margin="0,0,12,0" />
        <TextBlock Text="{Binding SuiteLabel}" Foreground="#96DC82" VerticalAlignment="Center" Margin="0,0,12,0"
                   IsVisible="{Binding SuiteLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <Button Content="Stop (Pause)" Command="{Binding StopCommand}" Background="#B43232" Foreground="White" Margin="0,0,8,0" />
        <Button Content="📷 Capture Screen" Command="{Binding CaptureScreenCommand}" Background="#3868A8" Foreground="White" Margin="0,0,8,0"
                ToolTip.Tip="Save a PNG of the whole desktop to %APPDATA%\Canary\captures — grabs warning balloons / modal toasts mid-run." />
        <Button Content="💾 Save Snapshot" Command="{Binding SaveSnapshotCommand}" Background="#5C8C50" Foreground="White"
                ToolTip.Tip="Freeze the last run's artifacts (candidates, manual-captures, logs) into &lt;testDir&gt;/archived/&lt;timestamp&gt;/ — preserves results without approving or rejecting them. Use this when iterating on infrastructure where you want to keep the screenshots but not commit to a baseline verdict." />
        <Button Content="📌 Override" Command="{Binding OverrideSnapshotCommand}" Background="#4C6B7D" Foreground="White" Margin="4,0,0,0"
                ToolTip.Tip="Phase 14.7 — Write the snapshot to a fixed &lt;testDir&gt;/archived/latest/ slot, replacing the prior 'latest' snapshot. Use this when you don't want a stack of timestamped snapshots — just the most recent one." />
      </WrapPanel>
    </Border>

    <ProgressBar Grid.Row="1" Minimum="0" Maximum="{Binding ProgressMax}" Value="{Binding ProgressValue}" Height="8" />

    <Grid Grid.Row="2" ColumnDefinitions="*,4,*">
      <ScrollViewer Grid.Column="0" Background="#141414">
        <ItemsControl ItemsSource="{Binding LogLines}" Padding="8">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <SelectableTextBlock Text="{Binding}"
                                   FontFamily="Consolas, Menlo, monospace"
                                   FontSize="12"
                                   Foreground="#C8C8C8" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <GridSplitter Grid.Column="1" Background="#404040" />

      <ScrollViewer Grid.Column="2" Background="#181818">
        <ItemsControl ItemsSource="{Binding ProgressCards}" Padding="8">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ProgressCard">
              <Border BorderBrush="#404040" BorderThickness="1" Margin="0,0,0,8" Padding="8" Background="#252526" CornerRadius="3">
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding CheckpointName}" FontWeight="Bold" Foreground="#DCDCDC" />
                  <TextBlock Text="{Binding TestName}" Foreground="#9696C8" FontSize="11" />
                  <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColor}" />
                  <TextBlock Text="{Binding VlmPrompt}" Foreground="#A0A0A0" TextWrapping="Wrap" FontSize="11"
                             IsVisible="{Binding VlmPrompt, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                  <TextBlock Text="{Binding VlmReasoning}" Foreground="#82B496" TextWrapping="Wrap" FontSize="11"
                             IsVisible="{Binding VlmReasoning, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                  <!-- BUG-0006 fix — animated-GIF in-card playback via the
                       custom AnimatedImagePanel (ImageSharp decode + plain
                       Image host). Replaces Avalonia.Labs.Gif which crashed
                       on null Source / missing-file / batch-bind. The runner
                       card's progressive Add pattern accidentally avoided
                       those crashes but the underlying control was still
                       brittle; swap for consistency with ResultsViewer. -->
                  <StackPanel Spacing="2"
                              IsVisible="{Binding GifPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <controls:AnimatedImagePanel SourcePath="{Binding GifPath}"
                                                 IsPlaying="True"
                                                 MaxHeight="240"
                                                 HorizontalAlignment="Left" />
                    <SelectableTextBlock Text="{Binding GifPath, StringFormat='🎞️ {0}'}"
                                         Foreground="#FFC850" TextWrapping="Wrap" FontSize="11"
                                         ToolTip.Tip="Animated GIF captured for this checkpoint. Open in Explorer for full-size playback." />
                  </StackPanel>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>
