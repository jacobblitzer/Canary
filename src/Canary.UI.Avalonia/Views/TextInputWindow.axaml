<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="mc"
        x:Class="Canary.UI.Avalonia.Views.TextInputWindow"
        Title="Add label"
        SizeToContent="WidthAndHeight"
        MinWidth="360"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <StackPanel Margin="12" Spacing="6">
    <TextBlock Text="Annotation text:" />
    <TextBox Name="InputBox" Width="320" />
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
      <Button Content="OK" Classes="accent" Click="OnOk" />
      <Button Content="Cancel" Click="OnCancel" />
    </StackPanel>
  </StackPanel>
</Window>
