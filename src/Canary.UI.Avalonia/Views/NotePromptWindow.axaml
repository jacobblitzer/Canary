<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="mc"
        x:Class="Canary.UI.Avalonia.Views.NotePromptWindow"
        Title="Add note"
        SizeToContent="WidthAndHeight"
        MinWidth="480"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <StackPanel Margin="12" Spacing="6">
    <TextBlock Text="Title:" />
    <TextBox Name="TitleBox" Width="440" />
    <TextBlock Text="Note:" Margin="0,6,0,0" />
    <TextBox Name="BodyBox" Width="440" Height="160" AcceptsReturn="True" TextWrapping="Wrap" />
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
      <Button Content="Capture" Classes="accent" Click="OnOk" />
      <Button Content="Cancel" Click="OnCancel" />
    </StackPanel>
  </StackPanel>
</Window>
