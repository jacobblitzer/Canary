<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Canary.UI.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
             x:Class="Canary.UI.Avalonia.Views.ResultsViewerView"
             x:DataType="vm:ResultsViewerViewModel">

  <Grid RowDefinitions="Auto,Auto,*,Auto">
    <Border Grid.Row="0" Background="#252526" Padding="12,8">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <TextBlock Text="{Binding Header}" FontSize="16" FontWeight="Bold" Foreground="#DCDCDC" VerticalAlignment="Center" />
        <Button Content="Approve All" Command="{Binding ApproveAllCommand}" Background="#007ACC" Foreground="White" />
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Background="#3A1F1F" Padding="12,6"
            IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
      <TextBlock Text="{Binding ErrorMessage}" Foreground="#FFB4B4" TextWrapping="Wrap" />
    </Border>

    <ScrollViewer Grid.Row="2" Padding="10">
      <ItemsControl ItemsSource="{Binding Cards}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:CheckpointCardViewModel">
            <Border BorderBrush="#404040" BorderThickness="1" Margin="0,0,0,10" Padding="10" Background="#252526" CornerRadius="3">
              <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="*,Auto">
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="12">
                  <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#DCDCDC" />
                  <TextBlock Text="{Binding TestName}" Foreground="#9696C8" />
                  <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColor}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                  <Button Content="Approve" Background="#3CC850" Foreground="White"
                          Command="{Binding $parent[ItemsControl].((vm:ResultsViewerViewModel)DataContext).ApproveCheckpointCommand}"
                          CommandParameter="{Binding}"
                          IsEnabled="{Binding !Resolved}" />
                  <Button Content="Reject" Background="#DC3C3C" Foreground="White"
                          Command="{Binding $parent[ItemsControl].((vm:ResultsViewerViewModel)DataContext).RejectCheckpointCommand}"
                          CommandParameter="{Binding}"
                          IsEnabled="{Binding !Resolved}" />
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Foreground="#A0A0A0" FontSize="11"
                           Text="{Binding DiffPercentage, StringFormat='Diff: {0:F2}%  ·  Tolerance: {1:F2}  ·  SSIM: {2:F3}'}" />

                <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="*,*,*" Margin="0,8,0,0">
                  <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="baseline" Foreground="#969696" FontSize="11" HorizontalAlignment="Center" />
                    <Image Source="{Binding BaselineThumb}" MaxHeight="180" Stretch="Uniform" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="candidate" Foreground="#969696" FontSize="11" HorizontalAlignment="Center" />
                    <Image Source="{Binding CandidateThumb}" MaxHeight="180" Stretch="Uniform" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="diff" Foreground="#969696" FontSize="11" HorizontalAlignment="Center" />
                    <Image Source="{Binding DiffThumb}" MaxHeight="180" Stretch="Uniform" />
                  </StackPanel>
                </Grid>

                <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Margin="0,8,0,0" Foreground="#82B496" TextWrapping="Wrap" FontSize="11"
                           Text="{Binding VlmReasoning}"
                           IsVisible="{Binding VlmReasoning, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <Border Grid.Row="3" Background="#007ACC" Padding="8,4">
      <TextBlock Text="{Binding StatusText}" Foreground="White" />
    </Border>
  </Grid>
</UserControl>
