<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Canary.UI.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="600"
             x:Class="Canary.UI.Avalonia.Views.SessionsLiveView"
             x:DataType="vm:SessionsLiveViewModel">

  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
    <!-- Row 0: top toolbar (workload picker + buttons). WrapPanel reflows
         on narrow widths instead of clipping (the WinForms bug we're
         migrating off). -->
    <Border Grid.Row="0" Background="#2D2D30" Padding="12,8">
      <WrapPanel Orientation="Horizontal">
        <ComboBox ItemsSource="{Binding Workloads}"
                  SelectedItem="{Binding SelectedWorkload, Mode=TwoWay}"
                  MinWidth="220"
                  Margin="0,4,8,4" />
        <Button Content="Start session"
                Command="{Binding StartCommand}"
                Classes="accent"
                Margin="0,4,8,4" />
        <Button Content="Capture (Ctrl+Shift+C)"
                Command="{Binding CaptureCommand}"
                Margin="0,4,8,4" />
        <Button Content="Capture + Annotate (Ctrl+Shift+A)"
                Command="{Binding CaptureAnnotateCommand}"
                Margin="0,4,8,4" />
        <Button Content="Capture with note"
                Command="{Binding CaptureWithNoteCommand}"
                Margin="0,4,8,4" />
        <Button Content="End session"
                Command="{Binding EndCommand}"
                Margin="0,4,8,4" />
      </WrapPanel>
    </Border>

    <!-- Row 1: status text. TextWrapping=Wrap is the fix for the
         clipped/overlapping status label that surfaced in WinForms. -->
    <TextBlock Grid.Row="1"
               Text="{Binding StatusText}"
               TextWrapping="Wrap"
               Foreground="#B4B4B4"
               Margin="12,4,12,4" />

    <!-- Row 2: hotkey hint. Separate row so it never overlaps status. -->
    <TextBlock Grid.Row="2"
               Text="{Binding HotkeyHint}"
               Foreground="#808080"
               FontSize="12"
               Margin="12,0,12,8" />

    <!-- Row 3: thumbnails header -->
    <TextBlock Grid.Row="3"
               Text="Captures in this session:"
               Foreground="#8C8C8C"
               FontSize="12"
               Margin="12,4,12,4" />

    <!-- Row 4: thumbnail strip in a ScrollViewer + WrapPanel -->
    <ScrollViewer Grid.Row="4" Background="#141414">
      <ItemsControl ItemsSource="{Binding Captures}" Padding="8">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:CaptureThumbnail">
            <Border BorderBrush="#404040"
                    BorderThickness="1"
                    Width="180" Height="124"
                    Margin="4" Padding="2"
                    Background="#252526">
              <Grid RowDefinitions="*,Auto">
                <Image Grid.Row="0"
                       Source="{Binding Thumbnail}"
                       Stretch="Uniform" />
                <TextBlock Grid.Row="1"
                           Text="{Binding Sequence, StringFormat=#{0:D3}}"
                           HorizontalAlignment="Center"
                           Foreground="#B4B4B4"
                           FontSize="11" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
