<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>Canary.UI</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWindowsForms>true</UseWindowsForms>
    <!-- Phase 5 / design §C5 + operator decision Q4: WPF island for the
         annotation surface (custom WPF Canvas embedded via ElementHost).
         Keeps the WinForms shell + dark theme; WPF only where it pulls
         its weight. -->
    <UseWPF>true</UseWPF>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Canary.Core\Canary.Core.csproj" />
    <ProjectReference Include="..\Canary.Agent\Canary.Agent.csproj" />
    <ProjectReference Include="..\Canary.Agent.Penumbra\Canary.Agent.Penumbra.csproj" />
    <ProjectReference Include="..\Canary.Agent.Qualia\Canary.Agent.Qualia.csproj" />
    <!-- Phase 2 (supervised-session): SessionsLiveSubPanel uses
         Canary.Harness.Session.SessionAgentFactory to construct the
         workload-specific bridge agent + dispatch on AgentType. The
         factory's logic mirrors RunCommand.cs and is single-sourced
         here rather than duplicated. -->
    <ProjectReference Include="..\Canary.Harness\Canary.Harness.csproj" />
  </ItemGroup>

  <!-- Phase 5: turning on UseWPF removes System.IO from the default
       implicit usings (.NET SDK quirk). Restore it explicitly so the
       existing WinForms files keep working without per-file changes. -->
  <ItemGroup>
    <Using Include="System.IO" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Canary.Tests" />
  </ItemGroup>

</Project>
