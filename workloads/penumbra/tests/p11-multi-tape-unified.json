{
  "name": "p11-multi-tape-unified",
  "workload": "penumbra",
  "description": "Phase 11 matrix \u00e2\u20ac\u201d Multi-Field, eval=tape, dispatchModel=unified. Should match p11-multi-tape-legacy pixel-for-pixel; divergence here means unified per-atom dispatch broke tape eval.",
  "setup": {
    "scene": {
      "index": 2,
      "sceneName": "Multi-Field"
    },
    "backend": "webgpu",
    "canvas": {
      "width": 960,
      "height": 540
    },
    "commands": [
      "window.__canaryHideUI(true)",
      "window.__canarySetDisplayMode('eval-tape')",
      "window.__canaryRenderer.setDisplayState({ render: { dispatchModel: 'unified' } })"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": {
        "azimuth": 30,
        "elevation": 20,
        "distance": 8
      },
      "stabilizeMs": 3000,
      "tolerance": 0.03
    }
  ]
}