{
  "name": "p11-teapot-atlas-unified",
  "workload": "penumbra",
  "description": "Phase 11 matrix \u00e2\u20ac\u201d SDF Teapot, eval=atlas, dispatchModel=unified. Single-field, many-atom atlas through the new per-atom dispatch. If this looks fine but Multi-Field doesn't, the bug is multi-field-specific.",
  "setup": {
    "scene": {
      "index": 5,
      "sceneName": "SDF Teapot (atlas CSG)"
    },
    "backend": "webgpu",
    "canvas": {
      "width": 960,
      "height": 540
    },
    "commands": [
      "window.__canaryHideUI(true)",
      "window.__canarySetDisplayMode('eval-atlas')",
      "window.__canaryRenderer.setDisplayState({ render: { dispatchModel: 'unified' } })"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": {
        "azimuth": 30,
        "elevation": 20,
        "distance": 10
      },
      "stabilizeMs": 12000,
      "tolerance": 0.04
    }
  ]
}