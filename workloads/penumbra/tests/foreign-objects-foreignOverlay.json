{
  "name": "foreign-objects-foreignOverlay",
  "workload": "penumbra",
  "description": "Foreign Objects (Phase 4) — foreign object overlay (green/magenta/cyan wireframes for mesh/NURBS/pointcloud)",
  "setup": {
    "scene": { "index": 10, "sceneName": "Foreign Objects (Phase 4)" },
    "backend": "webgpu",
    "canvas": { "width": 960, "height": 540 },
    "commands": [
      "window.__canaryToggleOverlay('foreignObjects')"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": { "azimuth": 0, "elevation": 15, "distance": 20 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    },
    {
      "name": "three-quarter",
      "camera": { "azimuth": 45, "elevation": 30, "distance": 20 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    },
    {
      "name": "top-down",
      "camera": { "azimuth": 0, "elevation": 80, "distance": 25 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    },
    {
      "name": "back",
      "camera": { "azimuth": 180, "elevation": 15, "distance": 20 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    }
  ]
}
