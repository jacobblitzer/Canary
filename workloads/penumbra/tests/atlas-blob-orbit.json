{
  "name": "atlas-blob-orbit",
  "workload": "penumbra",
  "description": "12-sphere smooth blob — baked atlas evaluation from 4 standard angles",
  "setup": {
    "scene": { "index": 1 },
    "backend": "webgpu",
    "canvas": { "width": 960, "height": 540 },
    "commands": []
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": { "azimuth": 0, "elevation": 15, "distance": 8 },
      "stabilizeMs": 800,
      "tolerance": 0.02
    },
    {
      "name": "side",
      "camera": { "azimuth": 90, "elevation": 15, "distance": 8 },
      "stabilizeMs": 800,
      "tolerance": 0.02
    },
    {
      "name": "three-quarter",
      "camera": { "azimuth": 45, "elevation": 30, "distance": 8 },
      "stabilizeMs": 800,
      "tolerance": 0.02
    },
    {
      "name": "top-down",
      "camera": { "azimuth": 0, "elevation": 80, "distance": 10 },
      "stabilizeMs": 800,
      "tolerance": 0.02
    }
  ]
}
