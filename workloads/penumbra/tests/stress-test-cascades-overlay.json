{
  "name": "stress-test-cascades-overlay",
  "workload": "penumbra",
  "description": "64-sphere stress test — cascade wireframe overlay (cascade coverage on large blob)",
  "setup": {
    "scene": { "index": 8, "sceneName": "64-Sphere Stress Test" },
    "backend": "webgpu",
    "canvas": { "width": 960, "height": 540 },
    "commands": [
      "new Promise(r => setTimeout(r, 10000))",
      "window.__canaryToggleOverlay('cascades')"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": { "azimuth": 0, "elevation": 15, "distance": 12 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    },
    {
      "name": "three-quarter",
      "camera": { "azimuth": 45, "elevation": 30, "distance": 12 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    },
    {
      "name": "top-down",
      "camera": { "azimuth": 0, "elevation": 80, "distance": 15 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    },
    {
      "name": "wide-angle",
      "camera": { "azimuth": 45, "elevation": 45, "distance": 20 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    }
  ]
}
