{
  "name": "columns-viz-normal",
  "workload": "penumbra",
  "description": "Repeated Columns — normal map visualization (repeated geometry normal correctness)",
  "setup": {
    "scene": { "index": 9, "sceneName": "Repeated Columns" },
    "backend": "webgpu",
    "canvas": { "width": 960, "height": 540 },
    "commands": [
      "window.__canarySetDisplayMode('viz-normal')"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": { "azimuth": 0, "elevation": 15, "distance": 20 },
      "stabilizeMs": 1000,
      "tolerance": 0.02
    },
    {
      "name": "three-quarter",
      "camera": { "azimuth": 45, "elevation": 30, "distance": 20 },
      "stabilizeMs": 1000,
      "tolerance": 0.02
    },
    {
      "name": "top-down",
      "camera": { "azimuth": 0, "elevation": 80, "distance": 26 },
      "stabilizeMs": 1000,
      "tolerance": 0.02
    },
    {
      "name": "back",
      "camera": { "azimuth": 180, "elevation": 15, "distance": 20 },
      "stabilizeMs": 1000,
      "tolerance": 0.02
    }
  ]
}
