{
  "name": "assembly-wire-cascades",
  "workload": "penumbra",
  "description": "Mechanical Assembly — cascade wireframe overlay (atlas cascade bounding boxes as wireframe)",
  "setup": {
    "scene": { "index": 7, "sceneName": "Mechanical Assembly (hybrid)" },
    "backend": "webgpu",
    "canvas": { "width": 960, "height": 540 },
    "commands": [
      "if (!window.__canaryGetAvailableModes().includes('wire-cascades')) throw new Error('Mode wire-cascades not available (no atlas)')",
      "window.__canarySetDisplayMode('wire-cascades')"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": { "azimuth": 0, "elevation": 15, "distance": 15 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    },
    {
      "name": "three-quarter",
      "camera": { "azimuth": 45, "elevation": 30, "distance": 15 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    },
    {
      "name": "top-down",
      "camera": { "azimuth": 0, "elevation": 80, "distance": 19 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    },
    {
      "name": "back",
      "camera": { "azimuth": 180, "elevation": 15, "distance": 15 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    }
  ]
}
