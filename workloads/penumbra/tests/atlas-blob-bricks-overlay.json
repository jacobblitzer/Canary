{
  "name": "atlas-blob-bricks-overlay",
  "workload": "penumbra",
  "description": "12-sphere blob — brick wireframe overlay (Alt+B) regression capture from 4 angles",
  "setup": {
    "scene": { "index": 1, "sceneName": "12-Sphere Blob" },
    "backend": "webgpu",
    "canvas": { "width": 960, "height": 540 },
    "commands": [
      "window.__canaryToggleOverlay('bricks')",
      "JSON.stringify(window.__canaryDiagnoseBricks())",
      "window.__canaryWaitForAtlasPipelineReady(120000)"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": { "azimuth": 0, "elevation": 0, "distance": 8 },
      "stabilizeMs": 1500,
      "tolerance": 0.02
    },
    {
      "name": "three-quarter",
      "camera": { "azimuth": 45, "elevation": 30, "distance": 8 },
      "stabilizeMs": 1500,
      "tolerance": 0.02
    },
    {
      "name": "top-down",
      "camera": { "azimuth": 0, "elevation": 85, "distance": 8 },
      "stabilizeMs": 1500,
      "tolerance": 0.02
    },
    {
      "name": "wide",
      "camera": { "azimuth": 30, "elevation": 20, "distance": 14 },
      "stabilizeMs": 1500,
      "tolerance": 0.02
    }
  ]
}
