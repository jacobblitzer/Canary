{
  "name": "tape-csg-custom-lighting",
  "workload": "penumbra",
  "description": "Box-Sphere CSG with custom lighting direction and intensity",
  "setup": {
    "scene": { "index": 0, "sceneName": "Box - Sphere" },
    "backend": "webgpu",
    "canvas": { "width": 960, "height": 540 },
    "commands": [
      "window.__canarySetLighting({direction:[0.9,0.1,0], intensity:2.5})"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": { "azimuth": 0, "elevation": 15, "distance": 8 },
      "stabilizeMs": 500,
      "tolerance": 0.02
    },
    {
      "name": "three-quarter",
      "camera": { "azimuth": 45, "elevation": 30, "distance": 8 },
      "stabilizeMs": 500,
      "tolerance": 0.02
    }
  ]
}
