{
  "name": "teapot-material-metal",
  "workload": "penumbra",
  "description": "SDF Teapot with Metal material preset (high metalness, low roughness)",
  "setup": {
    "scene": { "index": 5, "sceneName": "SDF Teapot (atlas CSG)" },
    "backend": "webgpu",
    "canvas": { "width": 960, "height": 540 },
    "commands": [
      "window.__canaryApplyMaterialPreset(window.__canaryGetFields()[0].id, 'metal')"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": { "azimuth": 0, "elevation": 15, "distance": 10 },
      "stabilizeMs": 500,
      "tolerance": 0.02
    },
    {
      "name": "three-quarter",
      "camera": { "azimuth": 45, "elevation": 30, "distance": 10 },
      "stabilizeMs": 500,
      "tolerance": 0.02
    }
  ]
}
