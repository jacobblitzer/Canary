{
  "name": "multi-field-point-cloud",
  "workload": "penumbra",
  "description": "Multi-Field — point cloud display mode (Fibonacci lattice sample points as colored dots)",
  "setup": {
    "scene": { "index": 2, "sceneName": "Multi-Field (3 primitives)" },
    "backend": "webgpu",
    "canvas": { "width": 960, "height": 540 },
    "commands": [
      "window.__canarySetDisplayMode('point-cloud')"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": { "azimuth": 0, "elevation": 15, "distance": 8 },
      "stabilizeMs": 500,
      "tolerance": 0.03
    },
    {
      "name": "three-quarter",
      "camera": { "azimuth": 45, "elevation": 30, "distance": 8 },
      "stabilizeMs": 500,
      "tolerance": 0.03
    },
    {
      "name": "top-down",
      "camera": { "azimuth": 0, "elevation": 80, "distance": 10 },
      "stabilizeMs": 500,
      "tolerance": 0.03
    },
    {
      "name": "back",
      "camera": { "azimuth": 180, "elevation": 15, "distance": 8 },
      "stabilizeMs": 500,
      "tolerance": 0.03
    }
  ]
}
