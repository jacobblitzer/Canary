{
  "name": "teapot-eval-tape",
  "workload": "penumbra",
  "description": "SDF Teapot — tape eval mode on atlas scene (quality comparison vs atlas path)",
  "setup": {
    "scene": { "index": 5, "sceneName": "SDF Teapot (atlas CSG)" },
    "backend": "webgpu",
    "canvas": { "width": 960, "height": 540 },
    "commands": [
      "window.__canarySetDisplayMode('eval-tape')"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": { "azimuth": 0, "elevation": 15, "distance": 10 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    },
    {
      "name": "three-quarter",
      "camera": { "azimuth": 45, "elevation": 30, "distance": 10 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    },
    {
      "name": "top-down",
      "camera": { "azimuth": 0, "elevation": 80, "distance": 13 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    },
    {
      "name": "back",
      "camera": { "azimuth": 180, "elevation": 15, "distance": 10 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    }
  ]
}
