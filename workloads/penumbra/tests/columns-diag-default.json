{
  "name": "columns-diag-default",
  "workload": "penumbra",
  "description": "Repeated Columns diagnostic — default lit rendering from 3/4 view",
  "setup": {
    "scene": { "index": 9, "sceneName": "Repeated Columns" },
    "backend": "webgpu",
    "canvas": { "width": 960, "height": 540 },
    "commands": [
      "new Promise(r => setTimeout(r, 5000))",
      "window.dispatchEvent(new KeyboardEvent('keydown', {key: 'q'}))"
    ]
  },
  "checkpoints": [
    {
      "name": "three-quarter",
      "camera": { "azimuth": 35, "elevation": 25, "distance": 18 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    }
  ]
}
