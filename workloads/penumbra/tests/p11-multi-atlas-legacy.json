{
  "name": "p11-multi-atlas-legacy",
  "workload": "penumbra",
  "description": "Phase 11 matrix \u00e2\u20ac\u201d Multi-Field, eval=atlas, dispatchModel=legacy. Pre-Phase-11 atlas path; should render all 3 fields with correct materials.",
  "setup": {
    "scene": {
      "index": 2,
      "sceneName": "Multi-Field"
    },
    "backend": "webgpu",
    "canvas": {
      "width": 960,
      "height": 540
    },
    "commands": [
      "window.__canaryHideUI(true)",
      "window.__canarySetDisplayMode('eval-atlas')",
      "window.__canaryRenderer.setDisplayState({ render: { dispatchModel: 'legacy' } })",
      "window.__canaryWaitForAtlasPipelineReady(120000)"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": {
        "azimuth": 30,
        "elevation": 20,
        "distance": 8
      },
      "stabilizeMs": 12000,
      "tolerance": 0.04
    }
  ]
}