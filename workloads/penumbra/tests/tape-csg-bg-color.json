{
  "name": "tape-csg-bg-color",
  "workload": "penumbra",
  "description": "Box-Sphere CSG with custom background color (purple-tinted)",
  "setup": {
    "scene": { "index": 0, "sceneName": "Box - Sphere" },
    "backend": "webgpu",
    "canvas": { "width": 960, "height": 540 },
    "commands": [
      "window.__canarySetBackgroundColor([0.2, 0.15, 0.25])"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": { "azimuth": 0, "elevation": 15, "distance": 8 },
      "stabilizeMs": 500,
      "tolerance": 0.02
    },
    {
      "name": "three-quarter",
      "camera": { "azimuth": 45, "elevation": 30, "distance": 8 },
      "stabilizeMs": 500,
      "tolerance": 0.02
    }
  ]
}
