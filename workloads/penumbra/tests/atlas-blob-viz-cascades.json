{
  "name": "atlas-blob-viz-cascades",
  "workload": "penumbra",
  "description": "12-sphere blob — cascade coverage visualization (LOD bands in distinct colors)",
  "setup": {
    "scene": { "index": 1, "sceneName": "12-Sphere Blob (Atlas)" },
    "backend": "webgpu",
    "canvas": { "width": 960, "height": 540 },
    "commands": [
      "window.__canarySetDisplayMode('viz-cascades')"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": { "azimuth": 0, "elevation": 15, "distance": 8 },
      "stabilizeMs": 800,
      "tolerance": 0.02
    },
    {
      "name": "three-quarter",
      "camera": { "azimuth": 45, "elevation": 30, "distance": 8 },
      "stabilizeMs": 800,
      "tolerance": 0.02
    },
    {
      "name": "top-down",
      "camera": { "azimuth": 0, "elevation": 80, "distance": 10 },
      "stabilizeMs": 800,
      "tolerance": 0.02
    },
    {
      "name": "back",
      "camera": { "azimuth": 180, "elevation": 15, "distance": 8 },
      "stabilizeMs": 800,
      "tolerance": 0.02
    }
  ]
}
