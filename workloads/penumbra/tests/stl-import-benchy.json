{
  "name": "stl-import-benchy",
  "workload": "penumbra",
  "description": "Load 3DBenchy STL via import pipeline, render as primitive-fit SDF from 4 angles",
  "setup": {
    "scene": null,
    "backend": "webgpu",
    "canvas": { "width": 960, "height": 540 },
    "commands": [
      "window.__canaryHideUI(true)",
      "window.__canarySetProgressiveQuality(false)",
      "(async () => { try { await window.__canaryLoadSTLFromUrl('/3dbenchy.stl'); return 'STL_OK'; } catch(e) { return 'STL_ERROR: ' + e.message + ' ||| STACK: ' + e.stack; } })()",
      "await new Promise(r => setTimeout(r, 1000))",
      "JSON.stringify(window.__canaryGetRendererInfo())"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": { "azimuth": 0, "elevation": 15, "distance": 120 },
      "stabilizeMs": 1000,
      "tolerance": 0.02
    },
    {
      "name": "side",
      "camera": { "azimuth": 90, "elevation": 15, "distance": 120 },
      "stabilizeMs": 800,
      "tolerance": 0.02
    },
    {
      "name": "three-quarter",
      "camera": { "azimuth": 45, "elevation": 30, "distance": 120 },
      "stabilizeMs": 800,
      "tolerance": 0.02
    },
    {
      "name": "top-down",
      "camera": { "azimuth": 0, "elevation": 80, "distance": 150 },
      "stabilizeMs": 800,
      "tolerance": 0.02
    }
  ]
}
