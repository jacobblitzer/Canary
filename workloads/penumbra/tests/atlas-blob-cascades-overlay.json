{
  "name": "atlas-blob-cascades-overlay",
  "workload": "penumbra",
  "description": "12-sphere blob — cascade grid wireframe overlay from 4 angles",
  "setup": {
    "scene": { "index": 1, "sceneName": "12-Sphere Blob (Atlas)" },
    "backend": "webgpu",
    "canvas": { "width": 960, "height": 540 },
    "commands": [
      "window.__canaryToggleOverlay('cascades')"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": { "azimuth": 0, "elevation": 15, "distance": 8 },
      "stabilizeMs": 1500,
      "tolerance": 0.02
    },
    {
      "name": "three-quarter",
      "camera": { "azimuth": 45, "elevation": 30, "distance": 8 },
      "stabilizeMs": 1500,
      "tolerance": 0.02
    },
    {
      "name": "top-down",
      "camera": { "azimuth": 0, "elevation": 80, "distance": 10 },
      "stabilizeMs": 1500,
      "tolerance": 0.02
    },
    {
      "name": "wide",
      "camera": { "azimuth": 30, "elevation": 20, "distance": 14 },
      "stabilizeMs": 1500,
      "tolerance": 0.02
    }
  ]
}
