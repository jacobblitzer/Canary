      "camera": { "azimuth": 45, "elevation": 30, "distance": 15 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    },
    {
      "name": "top-down",
      "camera": { "azimuth": 0, "elevation": 80, "distance": 19 },
      "stabilizeMs": 2000,
      "tolerance": 0.02
    },
    {
      "name": "back",
      "camera": { "azimuth": 180, "elevation": 15, "distance": 15 },
