{
  "name": "tape-csg-noise",
  "workload": "penumbra",
  "description": "Box-minus-sphere CSG — static noise displacement (amount 0.3, scale 1.0, speed 0)",
  "setup": {
    "scene": { "index": 0, "sceneName": "Box - Sphere" },
    "backend": "webgpu",
    "canvas": { "width": 960, "height": 540 },
    "commands": [
      "window.__canarySetFieldEffect(window.__canaryGetFields()[0].id, {noise:0.3, noiseScale:1.0, noiseSpeed:0})"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": { "azimuth": 0, "elevation": 15, "distance": 8 },
      "stabilizeMs": 500,
      "tolerance": 0.03
    },
    {
      "name": "three-quarter",
      "camera": { "azimuth": 45, "elevation": 30, "distance": 8 },
      "stabilizeMs": 500,
      "tolerance": 0.03
    }
  ]
}
