{
  "name": "p11-teapot-tape-unified",
  "workload": "penumbra",
  "description": "Phase 11 matrix \u00e2\u20ac\u201d SDF Teapot, eval=tape, dispatchModel=unified. The teapot has ~20 atoms in one field, so unified dispatch crosses many cell-atom-list lookups even in tape mode.",
  "setup": {
    "scene": {
      "index": 5,
      "sceneName": "SDF Teapot (atlas CSG)"
    },
    "backend": "webgpu",
    "canvas": {
      "width": 960,
      "height": 540
    },
    "commands": [
      "window.__canaryHideUI(true)",
      "window.__canarySetDisplayMode('eval-tape')",
      "window.__canaryRenderer.setDisplayState({ render: { dispatchModel: 'unified' } })"
    ]
  },
  "checkpoints": [
    {
      "name": "front",
      "camera": {
        "azimuth": 30,
        "elevation": 20,
        "distance": 10
      },
      "stabilizeMs": 3000,
      "tolerance": 0.03
    }
  ]
}