{
  "name": "diag-pencil-standard-debug-colors",
  "workload": "qualia",
  "description": "Standard profile + fx.debug-layer-colors — inside Papers qverse. Baseline for the debug palette without pencil-specific state.",
  "setup": {
    "canvas": { "width": 1280, "height": 800 },
    "commands": [
      "window.__canaryWaitForReady(30000)",
      "window.__canaryCloseLandingScreen()",
      "window.__canarySetTheme('dark')",
      "window.__canaryApplyProfile('standard')",
      "window.__canarySetPersonaEnabled('fx.debug-layer-colors', true)",
      "window.__canarySwitchContext('ctx-papers')",
      "window.__canaryResetAndRepel(1200)",
      "window.__canaryDumpDiagnostics()"
    ]
  },
  "checkpoints": [
    { "name": "diag-pencil-standard-debug-colors", "stabilizeMs": 3500, "tolerance": 0.3 }
  ]
}
