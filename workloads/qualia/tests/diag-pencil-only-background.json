{
  "name": "diag-pencil-only-background",
  "workload": "qualia",
  "description": "Pencil with nodes/edges/grid/gumball/labels all disabled — inside Papers qverse. Only scene.background should be visible. If it's NOT cream paper, fx.pencil-toon's background setter didn't run.",
  "setup": {
    "canvas": { "width": 1280, "height": 800 },
    "commands": [
      "window.__canaryWaitForReady(30000)",
      "window.__canaryCloseLandingScreen()",
      "window.__canarySetTheme('dark')",
      "window.__canaryApplyProfile('pencil')",
      "window.__canarySetPersonaEnabled('render.nodes', false)",
      "window.__canarySetPersonaEnabled('render.edges', false)",
      "window.__canarySetPersonaEnabled('render.grid', false)",
      "window.__canarySetPersonaEnabled('render.gumball', false)",
      "window.__canarySetPersonaEnabled('render.labels', false)",
      "window.__canarySwitchContext('ctx-papers')",
      "window.__canaryResetAndRepel(1200)",
      "window.__canaryDumpDiagnostics()"
    ]
  },
  "checkpoints": [
    { "name": "diag-pencil-only-background", "stabilizeMs": 3500, "tolerance": 0.3 }
  ]
}
