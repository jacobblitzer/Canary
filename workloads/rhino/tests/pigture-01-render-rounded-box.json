{
  "name": "pigture-01-render-rounded-box",
  "workload": "rhino",
  "description": "01 Render Rounded Box \u2014 orange PBR material on a box, 25-pass Cycles render via RenderScene \u002B RenderViewer.",
  "setup": {
    "file": "fixtures/pigture_slop_loader.gh",
    "viewport": {
      "width": 800,
      "height": 600,
      "projection": "Perspective",
      "displayMode": "Shaded"
    },
    "commands": [],
    "scene": null,
    "backend": "",
    "canvas": null,
    "vlm": null
  },
  "runMode": "shared",
  "recording": "",
  "checkpoints": [
    {
      "name": "render-output",
      "source": "file",
      "panelNickname": "RenderFilePath",
      "atTimeMs": 0,
      "tolerance": 0.08,
      "description": "Cycles render output of orange PBR material on rounded box",
      "mode": "pixel-diff",
      "camera": null,
      "stabilizeMs": null
    }
  ],
  "actions": [
    {
      "type": "WaitForGrasshopperSolution",
      "timeoutMs": 5000
    },
    {
      "type": "GrasshopperSetToggle",
      "nickname": "Build",
      "value": false
    },
    {
      "type": "GrasshopperSetToggle",
      "nickname": "Cleanup",
      "value": true
    },
    {
      "type": "WaitForGrasshopperSolution",
      "timeoutMs": 5000
    },
    {
      "type": "GrasshopperSetToggle",
      "nickname": "Cleanup",
      "value": false
    },
    {
      "type": "WaitForGrasshopperSolution",
      "timeoutMs": 2000
    },
    {
      "type": "GrasshopperSetPanelText",
      "nickname": "JsonPath",
      "text": "C:/Repos/Pigture/tests/slop/01_render_rounded_box.json"
    },
    {
      "type": "GrasshopperSetToggle",
      "nickname": "Build",
      "value": true
    },
    {
      "type": "WaitForGrasshopperSolution",
      "timeoutMs": 30000
    },
    {
      "type": "GrasshopperSetToggle",
      "nickname": "Run",
      "value": true
    },
    {
      "type": "WaitForGrasshopperSolution",
      "timeoutMs": 120000
    }
  ],
  "asserts": [
    {
      "type": "PanelEquals",
      "nickname": "SlopSuccess",
      "text": "True",
      "description": ""
    },
    {
      "type": "PanelDoesNotContain",
      "nickname": "SlopLog",
      "text": "FATAL",
      "description": ""
    },
    {
      "type": "PanelDoesNotContain",
      "nickname": "SlopLog",
      "text": "!!!",
      "description": ""
    }
  ],
  "keepOpenOnFailure": true
}