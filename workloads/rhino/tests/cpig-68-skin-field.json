            "value": false
        },
        {
            "type": "GrasshopperSetToggle",
            "nickname": "Cleanup",
            "value": true
        },
        {
            "type": "WaitForGrasshopperSolution",
            "timeoutMs": 5000
        },
        {
            "type": "GrasshopperSetToggle",
            "nickname": "Cleanup",
            "value": false
        },
        {
            "type": "WaitForGrasshopperSolution",
            "timeoutMs": 2000
        },
        {
            "type": "GrasshopperSetPanelText",
            "nickname": "JsonPath",
            "text": "C:/Repos/CPig/research/slop_tests/68_skin_field.json"
