{
    "name": "cpig-67-brep-trim",
    "workload": "rhino",
    "description": "67 Brep-Trim Field (R6.5 Phase E Batch 1 \u2014 Conformality)",
    "runMode": "shared",
    "setup": {
        "file": "fixtures/cpig_slop_loader.gh",
        "viewport": {
            "projection": "Perspective",
            "displayMode": "Shaded",
            "width": 800,
            "height": 600
        },
        "vlmDescription": "A light-blue rounded rectangular box shape filling the viewport, constrained to a rectangular boundary \u2014 not a sphere.",
        "whatItDoes": "Clips a source field to the inside of a closed Brep. Internally meshes the Brep, builds a signed-distance field, combines via max(F, brep_SDF). Errors if the Brep is open.",
        "whatYouShouldSee": "A light-blue rounded-box \u2014 the source field clipped to the Brep volume. Distinguish from Skin Field by the absence of a shell band."
    },
    "actions": [
        {
            "type": "WaitForGrasshopperSolution",
            "timeoutMs": 5000
        },
        {
            "type": "GrasshopperSetToggle",
            "nickname": "Build",
            "value": false
        },
        {
            "type": "GrasshopperSetToggle",
            "nickname": "Cleanup",
            "value": true
        },
        {
            "type": "WaitForGrasshopperSolution",
            "timeoutMs": 5000
        },
        {
            "type": "GrasshopperSetToggle",
            "nickname": "Cleanup",
            "value": false
        },
        {
            "type": "WaitForGrasshopperSolution",
            "timeoutMs": 2000
        },
        {
            "type": "GrasshopperSetPanelText",
            "nickname": "JsonPath",
            "text": "C:/Repos/CPig/research/slop_tests/67_brep_trim.json"
        },
        {
            "type": "GrasshopperSetToggle",
            "nickname": "Build",
            "value": true
        },
        {
            "type": "WaitForGrasshopperSolution",
            "timeoutMs": 30000
        }
    ],
    "checkpoints": [
        {
            "name": "post-build",
            "atTimeMs": 5000,
            "mode": "capture"
        }
    ],
    "asserts": [
        {
            "type": "PanelEquals",
            "nickname": "SlopSuccess",
            "text": "True"
        },
        {
            "type": "PanelDoesNotContain",
            "nickname": "SlopLog",
            "text": "FATAL"
        },
        {
            "type": "PanelDoesNotContain",
            "nickname": "SlopLog",
            "text": "!!!"
        }
    ]
}