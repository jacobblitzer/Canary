{
    "name": "cpig-34-retopo-constrain",
    "workload": "rhino",
    "description": "34 Retopo Constrain (auto-generated from 34_retopo_constrain.json)",
    "runMode": "shared",
    "setup": {
        "file": "fixtures/cpig_slop_loader.gh",
        "viewport": {
            "projection": "Perspective",
            "displayMode": "Shaded",
            "width": 800,
            "height": 600
        },
        "vlm": {
            "provider": "ollama",
            "model": "gemma4:e2b"
        },
        "vlmDescription": "A triangulated 3D sphere mesh shown in shaded mode against a grey background. No bright red feature polylines should be drawn \u2014 a smooth UV-sphere has no auto-detected sharp edges at the 30-degree dihedral threshold. The mesh shape is recognizably spherical."
    },
    "actions": [
        {
            "type": "WaitForGrasshopperSolution",
            "timeoutMs": 5000
        },
        {
            "type": "GrasshopperSetToggle",
            "nickname": "Build",
            "value": false
        },
        {
            "type": "GrasshopperSetToggle",
            "nickname": "Cleanup",
            "value": true
        },
        {
            "type": "WaitForGrasshopperSolution",
            "timeoutMs": 5000
        },
        {
            "type": "GrasshopperSetToggle",
            "nickname": "Cleanup",
            "value": false
        },
        {
            "type": "WaitForGrasshopperSolution",
            "timeoutMs": 2000
        },
        {
            "type": "GrasshopperSetPanelText",
            "nickname": "JsonPath",
            "text": "C:/Repos/CPig/research/slop_tests/34_retopo_constrain.json"
        },
        {
            "type": "GrasshopperSetToggle",
            "nickname": "Build",
            "value": true
        },
        {
            "type": "WaitForGrasshopperSolution",
            "timeoutMs": 60000
        }
    ],
    "checkpoints": [
        {
            "name": "post-build",
            "atTimeMs": 5000,
            "tolerance": 0.02
        }
    ],
    "asserts": [
        {
            "type": "PanelEquals",
            "nickname": "SlopSuccess",
            "text": "True"
        },
        {
            "type": "PanelDoesNotContain",
            "nickname": "SlopLog",
            "text": "FATAL"
        },
        {
            "type": "PanelDoesNotContain",
            "nickname": "SlopLog",
            "text": "!!!"
        }
    ]
}
