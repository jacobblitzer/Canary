{
    "name": "cpig-37-cross-field-instant",
    "workload": "rhino",
    "description": "37 Cross Field Instant (auto-generated from 37_cross_field_instant.json)",
    "runMode": "shared",
    "setup": {
        "file": "fixtures/cpig_slop_loader.gh",
        "viewport": {
            "projection": "Perspective",
            "displayMode": "Shaded",
            "width": 800,
            "height": 600
        },
        "vlm": {
            "provider": "ollama",
            "model": "gemma4:e2b"
        },
        "vlmDescription": "A triangulated sphere mesh shaded normally. Small bright dots may be visible on the surface marking cross-field singularities \u2014 a sphere typically has 8 valence-3/-5 singularities. Short vectors at face centroids may also appear if cross-field directions are visualized."
    },
    "actions": [
        {
            "type": "WaitForGrasshopperSolution",
            "timeoutMs": 5000
        },
        {
            "type": "GrasshopperSetToggle",
            "nickname": "Build",
            "value": false
        },
        {
            "type": "GrasshopperSetToggle",
            "nickname": "Cleanup",
            "value": true
        },
        {
            "type": "WaitForGrasshopperSolution",
            "timeoutMs": 5000
        },
        {
            "type": "GrasshopperSetToggle",
            "nickname": "Cleanup",
            "value": false
        },
        {
            "type": "WaitForGrasshopperSolution",
            "timeoutMs": 2000
        },
        {
            "type": "GrasshopperSetPanelText",
            "nickname": "JsonPath",
            "text": "C:/Repos/CPig/research/slop_tests/37_cross_field_instant.json"
        },
        {
            "type": "GrasshopperSetToggle",
            "nickname": "Build",
            "value": true
        },
        {
            "type": "WaitForGrasshopperSolution",
            "timeoutMs": 60000
        }
    ],
    "checkpoints": [
        {
            "name": "post-build",
            "atTimeMs": 5000,
            "tolerance": 0.02
        }
    ],
    "asserts": [
        {
            "type": "PanelEquals",
            "nickname": "SlopSuccess",
            "text": "True"
        },
        {
            "type": "PanelDoesNotContain",
            "nickname": "SlopLog",
            "text": "FATAL"
        },
        {
            "type": "PanelDoesNotContain",
            "nickname": "SlopLog",
            "text": "!!!"
        }
    ]
}
