{
  "name": "smoke-test",
  "workload": "rhino",
  "description": "Minimal smoke test — opens a file, captures a single screenshot to verify the pipeline works end-to-end.",
  "setup": {
    "viewport": {
      "width": 800,
      "height": 600,
      "projection": "Perspective",
      "displayMode": "Shaded"
    },
    "commands": [
      "_-Sphere _Center 0,0,0 _Radius 10 _Enter",
      "_ZoomExtents"
    ]
  },
  "checkpoints": [
    {
      "name": "after_sphere",
      "tolerance": 0.02
    }
  ]
}
