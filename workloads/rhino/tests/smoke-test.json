{
  "name": "smoke-test",
  "workload": "rhino",
  "description": "Minimal smoke test — opens a file, captures a single screenshot to verify the pipeline works end-to-end.",
  "setup": {
    "viewport": {
      "projection": "Perspective",
      "displayMode": "Shaded"
    },
    "commands": [
      "_-4View _Enter",
      "_-SetView _World _Perspective _Enter",
      "_-MaxViewport",
      "_-Sphere 0,0,0 10",
      "_-Zoom _All _Extents _Enter",
      "_SetDisplayMode _Mode=Shaded _Enter"
    ]
  },
  "checkpoints": [
    {
      "name": "after_sphere",
      "tolerance": 0.02
    }
  ]
}
